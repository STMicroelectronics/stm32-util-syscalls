{{assign 'syscallsFilter' (JSONparse '{"cgroup": "STM32CubeMX2 Config", "csub": "syscalls"}')~}}
{{assign 'syscalls_context' (@root.SWConfigurationAPI.getInstancesConfiguration @root.syscallsFilter)~}}
{{assign 'syscalls_cxt' @root.syscalls_context.[0].settings.parameters~}}
<?xml version="1.0" encoding="UTF-8"?>
<!-- ******************************************************************************
 * File Name   : {{@root.pdscAPI.getGPDSCFileName}}
 * Description : Generator PDSC File generated by CodeGen
 ******************************************************************************
  * @attention
